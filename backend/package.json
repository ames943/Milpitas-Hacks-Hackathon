{
  "name": "mosaic-backend",
  "version": "1.0.0",
  "description": "Mosaic mental health prediction backend",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "migrate": "ts-node src/scripts/migrate.ts",
    "test:survey": "ts-node --transpile-only src/scripts/test-survey.ts",
    "test:unit": "ts-node --transpile-only src/lib/scoring.test.ts",
    "test:signals": "ts-node --transpile-only src/lib/signals.test.ts",
    "test:routes": "ts-node --transpile-only src/routes/survey.test.ts",
    "test": "npm run test:unit && npm run test:signals && npm run test:dashboard && npm run test:exercises && npm run test:routes",
    "test:dashboard": "ts-node --transpile-only src/lib/dashboard.test.ts",
    "test:exercises": "ts-node --transpile-only src/lib/exercises.test.ts",
    "test:exercises-integration": "ts-node --transpile-only src/scripts/test-exercises-integration.ts",
    "test:exercises-live": "ts-node --transpile-only src/scripts/test-exercises-live.ts",
    "test:integration": "ts-node --transpile-only src/scripts/test-integration.ts",
    "test:transcript-live": "ts-node --transpile-only src/scripts/test-transcript-live.ts",
    "test:dashboard-integration": "ts-node --transpile-only src/scripts/test-dashboard-integration.ts",
    "test:dashboard-live": "ts-node --transpile-only src/scripts/test-dashboard-live.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@supabase/supabase-js": "^2.45.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "multer": "^2.1.1",
    "node-wav": "^0.0.2",
    "papaparse": "^5.5.3",
    "pdf-parse": "^2.4.5",
    "pitchfinder": "^2.3.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.0.0",
    "@types/papaparse": "^5.5.2",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.4"
  }
}
